# Conexão usada pelas funções da API. Em projetos Neon/Vercel, prefira a URL com pooler.
DATABASE_URL=postgresql://usuario:senha@host-pooler.neon.tech/neondb?sslmode=require

# Opcional: conexão direta, recomendada somente para migrações durante o deploy.
# Quando ausente, o deploy utiliza DATABASE_URL.
DATABASE_URL_UNPOOLED=postgresql://usuario:senha@host.neon.tech/neondb?sslmode=require

# Gere um segredo aleatório com pelo menos 32 caracteres.
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# Conta proprietária do Nexo PDV. Estes dados são sincronizados em cada deploy.
SUPER_ADMIN_EMAIL=admin@nexopdv.com.br
SUPER_ADMIN_PASSWORD=troque-por-uma-senha-forte-com-12-ou-mais-caracteres

# WhatsApp comercial: DDI + DDD + número, somente dígitos.
VITE_WHATSAPP_NUMBER=5571999999999

# Opcional: quando um Blob Store estiver conectado, imagens externas selecionadas
# podem ser copiadas para o armazenamento próprio. Uploads locais funcionam sem Blob.
BLOB_READ_WRITE_TOKEN=

# Relatórios de estoque por e-mail. Brevo é a opção gratuita sem domínio próprio.
BREVO_API_KEY=xkeysib-...
EMAIL_FROM=Nexo PDV <seuemail@gmail.com>

# Protege a rota executada pelo Vercel Cron. Use um valor longo e aleatório.
CRON_SECRET=troque-por-um-segredo-longo-e-aleatorio

# A busca é executada no navegador e não precisa de chave da JSON API.
